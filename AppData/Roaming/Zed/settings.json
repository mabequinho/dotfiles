{
  "show_inline_completions": false,
  "autosave": "on_focus_change",
  "ui_font_family": "FiraCode Nerd Font Mono",
  "ui_font_size": 16,
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 18,
  "tab_bar": {
    "show": true
  },
  "gutter": {
    "line_numbers": false
  },
  "auto_install_extensions": {
    "html": true
  },
  "features": {
    "inline_completion_provider": "none"
  },
  "tabs": {
    "git_status": true
  },
  "when_closing_with_no_tabs": "close_window",
  "restore_on_startup": "none",
  "soft_wrap": "editor_width",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "notification_panel": {
    "dock": "right"
  },
  "chat_panel": {
    "button": false
  },
  "terminal": {
    "font_size": 18,
    "font_weight": 600,
    "dock": "bottom",
    "copy_on_select": true,
    "shell": {
      "program": "nu"
    }
  },
  "auto_update": false,
  "assistant": {
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o"
    },
    "version": "2",
    "button": true,
    "enabled": true
  },
  "collaboration_panel": {
    "button": false
  },
  "project_panel": {
    "dock": "right"
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "languages": {
    "Markdown": {
      "show_inline_completions": false
    },
    "Python": {
      "show_inline_completions": true,
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["-", "-l 80"]
        }
      }
    },
    "lsp": {
      "omnisharp": {
        "binary": {
          "path": "/var/home/lucio/.omnisharp/OmniSharp",
          "args": ["optional", "additional", "args", "-lsp"]
        }
      }
    }
  }
}
